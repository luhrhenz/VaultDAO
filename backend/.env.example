PORT=8787
HOST=0.0.0.0
NODE_ENV=development
STELLAR_NETWORK=testnet
# Must be a valid http(s) URL
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Must be a valid http(s) URL
HORIZON_URL=https://horizon-testnet.stellar.org
# Replace this before production deploys
CONTRACT_ID=CDXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Must be a valid ws(s) URL
VITE_WS_URL=ws://localhost:8080

# Event Polling configuration
EVENT_POLLING_ENABLED=true
EVENT_POLLING_INTERVAL_MS=10000

# Request Body Limit (e.g., 10kb, 1mb)
REQUEST_BODY_LIMIT=10kb
